# ===== App =====
APP_NAME=trie-backend
DEBUG=true

# ===== Database (RDBMS) =====
# Dev default: local SQLite (zero setup). Prod (spec): PostgreSQL.
DATABASE_URL=sqlite:///./data/trie.db
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/trie

# ===== Storage =====
UPLOAD_DIR=./data/uploads
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=knowledge_documents

# ===== ③ Embedding (BGE-m3, local / free) =====
# EMBEDDING_BACKEND: bge-m3 (real, needs torch) | hashing (zero-dep dev stand-in)
EMBEDDING_BACKEND=bge-m3
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cpu          # or "cuda" if a GPU is available
EMBEDDING_BATCH_SIZE=16

# ===== ② Chunking =====
CHUNK_STRATEGY=semantic       # semantic | recursive
CHUNK_MAX_CHARS=1000
CHUNK_MIN_CHARS=200
CHUNK_OVERLAP_SENTENCES=1
SEMANTIC_BREAKPOINT_PERCENTILE=90

# ===== LLM / VLM (phases ②③⑤ — not used by the ingestion pipeline) =====
# Decision: free tier. Default = Google Gemini (free, vision, strong Korean).
# Offline alternative = Ollama (fully local, zero cost).
LLM_PROVIDER=gemini           # gemini | ollama | openai | anthropic
LLM_MODEL=gemini-2.0-flash
VLM_MODEL=gemini-2.0-flash
GEMINI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
