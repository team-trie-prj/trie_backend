# ===== App =====
APP_NAME=trie-backend
DEBUG=true

# ===== Database (RDBMS) =====
# Dev default: local SQLite (zero setup). Prod (spec): PostgreSQL.
DATABASE_URL=sqlite:///./data/trie.db
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/trie

# ===== Storage =====
UPLOAD_DIR=./data/uploads
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=knowledge_documents

# ===== ③ Embedding (BGE-m3, local / free) =====
# EMBEDDING_BACKEND: bge-m3 (real, needs torch) | hashing (zero-dep dev stand-in)
EMBEDDING_BACKEND=bge-m3
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cpu          # or "cuda" if a GPU is available
EMBEDDING_BATCH_SIZE=16

# ===== ② Chunking =====
CHUNK_STRATEGY=semantic       # semantic | recursive
CHUNK_MAX_CHARS=1000
CHUNK_MIN_CHARS=200
CHUNK_OVERLAP_SENTENCES=1
SEMANTIC_BREAKPOINT_PERCENTILE=90

# ===== ③ Agent =====
AGENT_AMBIGUITY_THRESHOLD=0.5

# ===== ④ Search / Rerank =====
RERANK_BACKEND=cross-encoder      # cross-encoder | none
RERANK_MODEL=BAAI/bge-reranker-v2-m3
SEARCH_TOP_K=20
SEARCH_FINAL_K=8
CONTEXT_MAX_TOKENS=3000

# ===== LLM / VLM (phases ②③⑤ — not used by the ingestion pipeline) =====
# Decision: free tier. Default = Google Gemini (free, vision, strong Korean).
# Offline alternative = Ollama (fully local, zero cost).
LLM_PROVIDER=gemini           # gemini | ollama | openai | anthropic
LLM_MODEL=gemini-2.5-flash
VLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# ===== Auth : OAuth2 (Kakao) — 김예담 =====
# AUTH_PROVIDER: kakao | mock  (KAKAO_CLIENT_ID 가 비면 자동으로 mock 폴백 → 오프라인 개발)
AUTH_PROVIDER=kakao
KAKAO_CLIENT_ID=              # Kakao Developers > 내 애플리케이션 > 앱 키 > REST API 키
KAKAO_CLIENT_SECRET=         # Kakao Developers > 카카오 로그인 > 보안 > Client Secret (활성화 시)
KAKAO_REDIRECT_URI=http://localhost:5173/oauth/kakao/callback   # 콘솔 등록값과 정확히 일치
# KAKAO_TOKEN_URL=https://kauth.kakao.com/oauth/token
# KAKAO_USERINFO_URL=https://kapi.kakao.com/v2/user/me

# ===== Auth : JWT =====
# 운영 필수: 길고 무작위한 값. 생성: python -c "import secrets;print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# ===== Security : 민감정보 암호화 (F5, Fernet) =====
# 생성: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=
